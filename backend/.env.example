# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=novel_user
MYSQL_PASSWORD=novel_password
MYSQL_DATABASE=novel_system

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Qdrant向量数据库配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=novel_memories

# OpenAI API配置
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# LLM提供商配置
# 可选值: openai, kimi, deepseek, yuanbao
LLM_PROVIDER=openai
CHAT2API_BASE_URL=http://localhost:8000

# 应用配置
APP_NAME=NovelGen System
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# 生成配置
MAX_CHAPTERS=1000
DEFAULT_CHAPTER_WORDS=3000
SUMMARY_INTERVAL=10
