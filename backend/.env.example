# KimiFiction 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 数据库配置
# ============================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=novel_user
MYSQL_PASSWORD=novel_password
MYSQL_DATABASE=novel_system

# ============================================
# Redis配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Qdrant向量数据库配置
# ============================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=novel_memories

# ============================================
# LLM提供商配置
# 推荐使用 DeepSeek（直接API，无需本地服务）
# 可选值: openai, kimi, deepseek, yuanbao, local_llama
# ============================================
LLM_PROVIDER=deepseek

# DeepSeek API（直接调用，推荐）
# 填写你的 DeepSeek API Key
DEEPSEEK_API_KEY=sk-1e54a266da00456bae8dd8edf8e54a89
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API（可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview

# chat2api服务地址（用于 Kimi/Yuanbao，本地需启动chat2api服务）
CHAT2API_BASE_URL=http://localhost:8000

# ============================================
# 本地Llama模型（用于Agentic RL训练，可选）
# ============================================
# Ollama 服务地址（如果没有运行Ollama请留空）
OLLAMA_BASE_URL=http://localhost:11434
# 本地模型文件目录
LOCAL_LLAMA_MODEL_PATH=D:/002 llm ware/models
LOCAL_LLAMA_MAX_TOKENS=2048
LOCAL_LLAMA_CONTEXT_WINDOW=4096

# ============================================
# 应用配置
# ============================================
APP_NAME=KimiFiction
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-in-production

# 后端服务端口
PORT=8080
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://127.0.0.1:5173","http://127.0.0.1:5174"]

# 生成配置
MAX_CHAPTERS=1000
DEFAULT_CHAPTER_WORDS=3000
SUMMARY_INTERVAL=10

# 前端API地址
VITE_API_URL=http://localhost:8080/api/v1
